  ITEMS_DEF.forEach(it=>{m[it.id]={ss_actuel:ss_vals[it.id]||100,uom:"PCS"};});
  return m;
}

function calcBiasForPair(last,prev,weeks){
  const errors=weeks.map(w=>(last?.qtys[w]||0)-(prev?.qtys[w]||0));
  const n=errors.length;
  const cumBias=errors.reduce((a,b)=>a+b,0);
  const meanBias=cumBias/n;
  const mad=errors.reduce((a,b)=>a+Math.abs(b),0)/n;
  const prevMean=weeks.map(w=>prev?.qtys[w]||0).reduce((a,b)=>a+b,0)/n;
  const biasPct=prevMean>0?Math.round(meanBias/prevMean*1000)/10:0;
  const ts=mad>0?Math.round(cumBias/mad*100)/100:0;
  return{cumBias:Math.round(cumBias),meanBias:Math.round(meanBias*10)/10,biasPct,mad:Math.round(mad),ts,prevMean:Math.round(prevMean),direction:cumBias>0?"Sur-prog.":"Sous-prog."};
}

function calcMetrics(receptions,cfg){
  const last=receptions[receptions.length-1];
  const prev=receptions[receptions.length-2];
  if(!last||!prev)return null;
  const zones={frozen:[],slushy:[],liquid:[]};
  WEEKS.forEach(w=>zones[getZone(w)].push(w));
  const result={};
  Object.entries(zones).forEach(([z,weeks])=>{
    const b=calcBiasForPair(last,prev,weeks);
    const thresh=cfg.ts[z];
    result[z]={...b,thresh,tsFlag:Math.abs(b.ts)>thresh,biasFlag:Math.abs(b.biasPct)>cfg.biasDanger,flag:Math.abs(b.ts)>thresh||Math.abs(b.biasPct)>cfg.biasDanger};
  });
  return result;
}

function calcSS(mad,serviceLevel){
  const Z={90:1.28,95:1.65,98:2.05,99:2.33};
  return Math.round((Z[serviceLevel]||1.65)*mad);
}

function classifyDemand(receptions){
  const last=receptions[receptions.length-1];
  if(!last)return{type:"N/A",color:NAV.ok};
  const qtys=WEEKS.map(w=>last.qtys[w]||0);
  const mean=qtys.reduce((a,b)=>a+b,0)/qtys.length;
  const variance=qtys.reduce((a,b)=>a+(b-mean)**2,0)/qtys.length;
  const cv=mean>0?Math.sqrt(variance)/mean:0;
  const trend=qtys[qtys.length-1]-qtys[0];
  const seasonal=Math.max(...qtys)/(Math.min(...qtys)||1)>1.5;
  if(cv<0.2&&Math.abs(trend)<mean*0.1)return{type:"Stable",color:NAV.ok};
  if(Math.abs(trend)>mean*0.3)return{type:"Tendance "+(trend>0?"↑":"↓"),color:NAV.accent};
  if(seasonal)return{type:"Saisonnière",color:NAV.warn};
  return{type:"Aléatoire",color:NAV.danger};
}

function getBiasTag(biasPct,cfg){
  const a=Math.abs(biasPct);
  if(a<cfg.biasWarn)return{label:"Biais faible",color:NAV.ok};
  if(a<cfg.biasDanger)return{label:"Biais modéré",color:NAV.warn};
  return{label:"Biais fort",color:NAV.danger};
}

function clientScore(items,ediData,cfg){
  let totalFlags=0,totalZones=0;
  items.forEach(it=>{
    const m=calcMetrics(ediData[it.id],cfg);
    if(!m)return;
    Object.values(m).forEach(v=>{totalZones++;if(v.flag)totalFlags++;});
  });
  return totalZones>0?Math.round((1-totalFlags/totalZones)*100):100;
}

