function getAllFlags(){
  const flags=[];
  ITEMS_DEF.forEach(it=>{
    if(S.clientFilter!=="all"&&it.cli!==S.clientFilter)return;
    const m=calcMetrics(S.ediData[it.id],getCfg(it.cli));
    if(!m)return;
    Object.entries(m).forEach(([z,v])=>{if(v.flag)flags.push({item:it,zone:z,...v});});
  });
  return flags;
}

function parseEDICSV(text,fileName){
  const lines=text.split(/\r?\n/).filter(l=>l.trim()&&l.replace(/;/g,"").trim());
  const meta={};let headerIdx=-1,dataRows=[],columns=[],periods=[],bucket="week";
  for(let i=0;i<lines.length;i++){
    const cells=lines[i].split(";").map(c=>c.trim().replace(/^\uFEFF/,"").replace(/"/g,""));
    const k=cells[0].toUpperCase();
    if(k==="EMETTEUR")meta.emetteur=cells[1];
    else if(k==="DATE_EMISSION")meta.date=cells[1];
    else if(k==="RECEPTION_NUM")meta.reception=cells[1];
    else if(k==="REFERENCE"){headerIdx=i;columns=cells;periods=columns.filter(c=>c.match(/^S\d+$|^\d{2}\/\d{2}$/));bucket=periods.length>0&&periods[0].match(/^\d{2}\/\d{2}$/)?"day":"week";}
    else if(headerIdx>-1&&cells[0].startsWith("REF-")){
      const row={};columns.forEach((col,ci)=>{row[col]=cells[ci]||"";});
      row._qtys={};periods.forEach(p=>{row._qtys[p]=parseInt(row[p])||0;});
      row._periods=periods;row._bucket=bucket;dataRows.push(row);
    }
  }
  return{meta,columns,periods,bucket,dataRows,errors:[],valid:true,fileName};
}

function parseItemMasterCSV(text){
  const lines=text.split(/\r?\n/).filter(l=>l.trim());
  const result={};
  lines.forEach((line,i)=>{
    if(i===0)return;
    const cells=line.split(";").map(c=>c.trim().replace(/^\uFEFF/,"").replace(/"/g,""));
    if(cells[0]&&cells[1])result[cells[0]]={ss_actuel:parseInt(cells[1])||0,uom:cells[2]||"PCS"};
  });
  return result;
}

