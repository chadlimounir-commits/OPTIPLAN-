      return`<div class="card" style="border:1.5px solid ${v.flag?NAV.danger:"#E2E8F0"}">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
          <span class="pill" style="background:${z==="frozen"?NAV.accent:z==="slushy"?NAV.warn:NAV.teal}22;color:${z==="frozen"?NAV.accent:z==="slushy"?NAV.warn:NAV.teal}">${z.charAt(0).toUpperCase()+z.slice(1)}</span>
          ${v.flag?`<span style="font-size:10px;color:${NAV.danger};font-weight:700">ALERTE</span>`:""}
