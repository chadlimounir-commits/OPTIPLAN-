          <div style="flex:1;text-align:center;border-left:0.5px solid #E2E8F0"><div class="lbl">Tracking Signal</div><div style="font-size:18px;font-weight:700;color:${v.tsFlag?NAV.danger:"#1E293B"}">${v.ts}</div></div>
