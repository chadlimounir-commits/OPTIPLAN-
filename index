const WEEKS=["S1","S2","S3","S4","S5","S6","S7","S8","S9","S10","S11","S12"];
function getZone(w){const i=parseInt(w.replace("S",""));return i<=2?"frozen":i<=5?"slushy":"liquid";}

function rng(s){let x=Math.sin(s)*10000;return x-Math.floor(x);}
function buildEDI(seed,reception){
  const base=WEEKS.map((_,i)=>Math.round(80+rng(seed+i)*280));
  const qtys={};
  WEEKS.forEach((w,i)=>{
    const drift=reception>2?(rng(seed+reception*7+i)>0.55?1.35+rng(seed+reception+i)*0.7:0.72+rng(seed+reception+i)*0.28):1;
    qtys[w]=Math.round(base[i]*drift);
  });
  const d=new Date(2024,reception-1,1);
  return{id:`R${String(reception).padStart(2,"0")}`,date:d.toLocaleDateString("fr-FR"),dateObj:d,qtys};
}

function buildAllEDI(){
  const h={};
  ITEMS_DEF.forEach((it,idx)=>{h[it.id]=[];for(let r=1;r<=6;r++)h[it.id].push(buildEDI((idx+1)*17,r));});
  return h;
}

