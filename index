function attachEvents(){
  document.querySelectorAll("[data-cfg][data-ts]").forEach(el=>{
    el.addEventListener("change",e=>{
      const cli=el.dataset.cfg,z=el.dataset.ts;
      const nc=JSON.parse(JSON.stringify(S.clientCfgs));
      nc[cli].ts[z]=+e.target.value;ss({clientCfgs:nc});
    });
  });
  document.querySelectorAll("[data-cfg][data-bias]").forEach(el=>{
    el.addEventListener("change",e=>{
      const cli=el.dataset.cfg,k=el.dataset.bias==="warn"?"biasWarn":"biasDanger";
      const nc=JSON.parse(JSON.stringify(S.clientCfgs));
      nc[cli][k]=+e.target.value;ss({clientCfgs:nc});
    });
  });
  document.querySelectorAll("[data-sl]").forEach(el=>{
    el.addEventListener("change",e=>{
      const cli=el.dataset.cfg||S.cfgClient;
      const nc=JSON.parse(JSON.stringify(S.clientCfgs));
      nc[cli].service=+e.target.value;ss({clientCfgs:nc});
    });
  });
  const dh=document.querySelector("[data-help-search]");
  if(dh)dh.addEventListener("input",e=>ss({helpSearch:e.target.value}));
  const dropEDI=document.getElementById("dropEDI");
  const fileEDI=document.getElementById("fileEDI");
  if(dropEDI){
    dropEDI.addEventListener("dragover",e=>{e.preventDefault();dropEDI.classList.add("drag");});
    dropEDI.addEventListener("dragleave",()=>dropEDI.classList.remove("drag"));
    dropEDI.addEventListener("drop",e=>{e.preventDefault();dropEDI.classList.remove("drag");handleEDIFiles(e.dataTransfer.files);});
  }
  if(fileEDI)fileEDI.addEventListener("change",e=>handleEDIFiles(e.target.files));
  const dropM=document.getElementById("dropMaster");
  const fileM=document.getElementById("fileMaster");
  if(dropM){
    dropM.addEventListener("dragover",e=>{e.preventDefault();dropM.classList.add("drag");});
    dropM.addEventListener("dragleave",()=>dropM.classList.remove("drag"));
    dropM.addEventListener("drop",e=>{e.preventDefault();dropM.classList.remove("drag");handleMasterFile(e.dataTransfer.files[0]);});
  }
  if(fileM)fileM.addEventListener("change",e=>handleMasterFile(e.target.files[0]));
  const btn=document.getElementById("btnDoImport");
  if(btn)btn.addEventListener("click",doImport);
}

function handleEDIFiles(files){
  const arr=[...files];let done=0;const parsed=[];
  arr.forEach(f=>{
    const r=new FileReader();
    r.onload=e=>{parsed.push(parseEDICSV(e.target.result,f.name));done++;
      if(done===arr.length){
        S.importedFiles=parsed;
        const el=document.getElementById("ediFileList");
        if(el)el.innerHTML=parsed.map(p=>`<div style="display:flex;align-items:center;gap:6px;margin-top:6px;padding:6px 8px;background:#F8FAFC;border-radius:6px;font-size:10px">
          <i class="ti ti-file-spreadsheet" style="color:${NAV.ok}"></i>
          <span style="flex:1;font-weight:600">${p.fileName}</span>
          <span style="color:#64748B">${p.dataRows.length} réf.</span>
          <span class="pill" style="background:${NAV.ok}22;color:${NAV.ok}">✓</span>
        </div>`).join("");
        const preview=document.getElementById("importPreview");
        if(preview)preview.innerHTML=`<div style="background:${NAV.accent}12;border:0.5px solid ${NAV.accent}44;border-radius:8px;padding:10px;font-size:11px;color:#64748B">
          <strong style="color:${NAV.accent}">${parsed.length} fichier(s) · ${parsed.reduce((a,f)=>a+f.dataRows.length,0)} références détectées</strong>
          ${parsed.map(f=>`<div style="margin-top:4px">${f.fileName} · ${f.meta.reception||"?"} · ${f.dataRows.length} réf.</div>`).join("")}
        </div>`;
        const act=document.getElementById("importActions2");
        if(act)act.style.display="block";
      }
    };
    r.readAsText(f,"utf-8");
  });
}

function handleMasterFile(file){
  if(!file)return;
  const r=new FileReader();
  r.onload=e=>{
    const newMaster=parseItemMasterCSV(e.target.result);
    const count=Object.keys(newMaster).length;
    S.itemMaster={...S.itemMaster,...newMaster};
    const el=document.getElementById("masterStatus");
    if(el)el.innerHTML=`<div style="padding:6px 8px;background:${NAV.ok}18;border-radius:6px;font-size:10px;color:${NAV.ok};font-weight:600;margin-top:6px">
      <i class="ti ti-circle-check" style="margin-right:4px"></i>${count} articles importés
    </div>`;
  };
  r.readAsText(file,"utf-8");
}

function doImport(){
  S.importedFiles.forEach(f=>{
    f.dataRows.forEach(row=>{
      const ref=row.REFERENCE;
      const it=ITEMS_DEF.find(i=>i.id===ref);
      if(!it)return;
      const recs=S.ediData[ref]||[];
      S.ediData[ref]=[...recs.slice(-5),{id:f.meta.reception||`R${String(recs.length+1).padStart(2,"0")}`,date:f.meta.date||new Date().toLocaleDateString("fr-FR"),dateObj:new Date(),qtys:row._qtys,clientId:it.cli}];
    });
  });
  S.importedFiles=[];
  const suc=document.getElementById("importSuccess");
  if(suc)suc.style.display="block";
  const act=document.getElementById("importActions2");
  if(act)act.style.display="none";
  setTimeout(()=>ss({showImport:false}),1500);
}



// ── GOOGLE SHEETS CONNECTOR ──────────────────────────────────
// Remplacer cette URL par l'URL de déploiement de votre Apps Script
let APPS_SCRIPT_URL = "";

const GSConnector = {
  isConfigured: () => APPS_SCRIPT_URL !== "",

  async get(action, params = {}) {
    if (!this.isConfigured()) return null;
    const url = new URL(APPS_SCRIPT_URL);
    url.searchParams.set("action", action);
    Object.entries(params).forEach(([k, v]) => url.searchParams.set(k, v));
    try {
      const r = await fetch(url.toString());
      return await r.json();
    } catch(e) { console.error("GS GET error:", e); return null; }
  },

  async post(action, data) {
    if (!this.isConfigured()) return null;
    try {
      const r = await fetch(APPS_SCRIPT_URL, {
        method: "POST",
        body: JSON.stringify({ action, data }),
      });
      return await r.json();
    } catch(e) { console.error("GS POST error:", e); return null; }
  },

  // Load all data from Google Sheets
  async loadAll() {
    const [cfgRes, itemsRes] = await Promise.all([
      this.get("getConfig"),
      this.get("getItems"),
    ]);
    if (cfgRes?.status === "ok") {
      const cfgMap = {};
      cfgRes.data.forEach(c => { cfgMap[c.id] = c; });
      S.clientCfgs = cfgMap;
    }
    if (itemsRes?.status === "ok") {
      // Extend ITEMS_DEF with live data — merge
      itemsRes.data.forEach(it => {
        const ex = ITEMS_DEF.find(i => i.id === it.id);
        if (ex) { Object.assign(ex, it); }
        if (S.itemMaster[it.id]) S.itemMaster[it.id].ss_actuel = it.ss_actuel;
      });
    }
    const ediRes = await this.get("getEDIHistory");
    if (ediRes?.status === "ok") {
      Object.entries(ediRes.data).forEach(([ref, recs]) => {
        if (recs.length > 0) S.ediData[ref] = recs;
      });
    }
    ss({});
    return true;
  },

  // Push config change for one client
  async pushConfig(clientId) {
    const cfg = S.clientCfgs[clientId];
    const clDef = CLIENTS_DEF.find(c => c.id === clientId);
    return this.post("saveConfig", { id: clientId, label: clDef?.label, color: clDef?.color, ...cfg });
  },

  // Push EDI import
  async pushEDI(parsedFile) {
    const rows = [];
    parsedFile.dataRows.forEach(row => {
      const it = ITEMS_DEF.find(i => i.id === row.REFERENCE);
      if (!it) return;
      rows.push({ ref: row.REFERENCE, clientId: it.cli, bucket: row._bucket || "week", qtys: row._qtys });
    });
    return this.post("importEDI", {
      fileName: parsedFile.fileName,
      meta: parsedFile.meta,
      rows,
    });
  },

  // Push Item Master update
  async pushMaster(masterData) {
    const rows = Object.entries(masterData).map(([ref, v]) => ({ ref, ss_actuel: v.ss_actuel, uom: v.uom }));
    return this.post("importMaster", rows);
  },
};

